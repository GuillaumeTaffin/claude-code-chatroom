{
  "name": "@chatroom/spawner",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "scripts": {
    "dev": "bun --watch src/index.ts",
    "check:types": "tsc --noEmit -p tsconfig.json",
    "check:test:unit": "vitest run --config vitest.unit.config.ts",
    "check:test:component": "vitest run --config vitest.component.config.ts",
    "check:test:integration": "vitest run --config vitest.integration.config.ts",
    "check:test": "bun run check:test:unit && bun run check:test:component && bun run check:test:integration",
    "check:coverage": "vitest run --config vitest.unit.config.ts --coverage",
    "check:lint": "eslint .",
    "check:format": "prettier --check . --ignore-path ../../.prettierignore",
    "check:all": "bun run check:types && bun run check:test && bun run check:coverage && bun run check:lint && bun run check:format"
  },
  "dependencies": {
    "@chatroom/connector-core": "workspace:*",
    "@chatroom/shared": "workspace:*"
  },
  "devDependencies": {
    "bun-types": "latest"
  }
}
