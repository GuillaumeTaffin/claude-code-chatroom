{
	"name": "@chatroom/web",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
		"check:types": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json",
		"check:types:watch": "svelte-kit sync && svelte-check --tsconfig ./tsconfig.json --watch",
		"check:test": "vitest run --config vitest.config.ts",
		"check:coverage": "vitest run --config vitest.config.ts --coverage",
		"check:lint": "eslint .",
		"check:format": "prettier --check . --ignore-path ../../.prettierignore",
		"check:all": "bun run check:types && bun run check:test && bun run check:coverage && bun run check:lint && bun run check:format"
	},
	"dependencies": {
		"@chatroom/shared": "workspace:*"
	},
	"devDependencies": {
		"@tailwindcss/vite": "^4.0.0",
		"tailwindcss": "^4.0.0",
		"@sveltejs/adapter-auto": "^7.0.0",
		"@sveltejs/kit": "^2.50.2",
		"@sveltejs/vite-plugin-svelte": "^6.2.4",
		"svelte": "^5.54.0",
		"svelte-check": "^4.4.2",
		"typescript": "^5.9.3",
		"vite": "^7.3.1"
	}
}
