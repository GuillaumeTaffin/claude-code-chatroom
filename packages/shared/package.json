{
  "name": "@chatroom/shared",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "scripts": {
    "check:types": "tsc --noEmit -p tsconfig.json",
    "check:test": "vitest run --config vitest.config.ts",
    "check:coverage": "vitest run --config vitest.config.ts --coverage",
    "check:lint": "eslint .",
    "check:format": "prettier --check . --ignore-path ../../.prettierignore",
    "check:all": "bun run check:types && bun run check:test && bun run check:coverage && bun run check:lint && bun run check:format"
  },
  "main": "src/index.ts",
  "types": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  }
}
